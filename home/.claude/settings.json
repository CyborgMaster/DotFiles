{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/notify.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "10x-engineer@claude-templates": true,
    "claude-hud-meta@claude-templates": true,
    "code_provenance@Meta": true,
    "llm-rules@Meta": true,
    "meta@Meta": true,
    "meta_codesearch@Meta": true,
    "meta_knowledge@Meta": true,
    "trajectory@Meta": true
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark"
}
